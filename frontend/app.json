{
  "expo": {
    "name": "AM Coaching",
    "slug": "am-coaching-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "am-coaching",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.am.coaching",
      "buildNumber": "1.0.0",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "NSPhotoLibraryUsageDescription": "AM Coaching necesita acceder a tu galería para que puedas subir vídeos de tus ejercicios para la corrección técnica.",
        "NSCameraUsageDescription": "AM Coaching necesita usar la cámara para que puedas grabarte realizando los ejercicios.",
        "NSMicrophoneUsageDescription": "AM Coaching necesita acceso al micrófono para grabar el audio de tus vídeos de entrenamiento."
      }
    },
    "android": {
      "package": "com.am.coaching",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "display": "standalone",
      "backgroundColor": "#000000",
      "themeColor": "#4A90E2",
      "lang": "es",
      "config": {
        "pwa": {
          "manifest": {
            "name": "AM Coaching",
            "short_name": "AM Coaching",
            "description": "Programación y seguimiento de deportistas",
            "start_url": "/",
            "display": "standalone",
            "orientation": "portrait",
            "background_color": "#000000",
            "theme_color": "#4A90E2",
            "icons": [
              {
                "src": "./assets/images/icon.png",
                "sizes": "192x192",
                "type": "image/png"
              },
              {
                "src": "./assets/images/icon.png",
                "sizes": "512x512",
                "type": "image/png"
              }
            ]
          }
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c3d7138d-2af2-443e-be34-054053e8ac03"
      }
    }
  }
}
